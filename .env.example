# Copy this file to ".env" and fill in your own values.
# The real ".env" is git-ignored and must NEVER be committed.

# --- Optional: faster live updates from football-data.org ---------------
# Free key (10 requests/min): https://www.football-data.org/client/register
# Leave blank to run fully free with the no-key openfootball source.
FOOTBALL_DATA_API_KEY=

# --- Optional overrides --------------------------------------------------
# How often the backend pulls from upstream (seconds).
REFRESH_SECONDS=30
# Server bind address / port.
HOST=127.0.0.1
PORT=8765
# Display timezone for kickoff times & "today" (IANA name, e.g.
# America/New_York). Blank = the machine's local timezone.
DISPLAY_TIMEZONE=
# Override the openfootball data URL if you mirror it yourself.
# OPENFOOTBALL_URL=
